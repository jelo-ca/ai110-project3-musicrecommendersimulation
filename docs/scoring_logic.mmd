flowchart TD
    U([UserProfile])
    S([Song])

    U --> UG[favorite_genre]
    U --> UM[favorite_mood]
    U --> UE[target_energy]
    U --> UA[likes_acoustic]

    S --> SG[genre]
    S --> SM[mood]
    S --> SE[energy]
    S --> SV[valence]
    S --> SD[danceability]
    S --> SAC[acousticness]

    UG & SG --> GM{"genre\nmatch?"}
    UM & SM --> MM{"mood\nmatch?"}
    UE & SE --> ED["1 - |song.energy - user.target_energy|"]
    UA & SAC --> AB{"likes_acoustic\n== True?"}
    SV --> VB["valence score"]

    GM -->|"yes → +3.0\nno  → +0.0"| SCORE
    MM -->|"yes → +2.0\nno  → +0.0"| SCORE
    ED -->|"× 1.5"| SCORE
    AB -->|"yes → acousticness × 1.0\nno  → +0.0"| SCORE
    VB -->|"valence × 0.5"| SCORE

    SCORE["Total Score\n= genre_match×3.0\n+ mood_match×2.0\n+ energy_closeness×1.5\n+ acousticness_bonus×1.0\n+ valence×0.5"]

    SCORE --> RANK["Rank all songs\nby score ↓"]
    RANK --> OUT["Return top-k\nrecommendations"]
